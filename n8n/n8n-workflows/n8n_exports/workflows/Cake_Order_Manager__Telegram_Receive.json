                  {
                      "parameters":  {
                                         "jsCode":  "const message = $(\u0027Telegram Trigger\u0027).first().json.message\nconst image_exists = message.photo != null\nconst file_id = image_exists ? message.photo[1].file_id : null\nconst customer_id = message.from.id\nconst user_message = message.text || message.caption\nreturn {image_exists, file_id, customer_id, user_message}"
                                     },
                      "type":  "n8n-nodes-base.code",
                      "typeVersion":  2,
                      "position":  [
                                       64,
                                       -16
                                   ],
                      "id":  "30dd52aa-a678-4689-b9db-60e73b180df1",
                      "name":  "Code in JavaScript"
                  },
                  {
                      "parameters":  {
                                         "jsCode":  "const message = $input.first().json.message\nconst input = message.text || message.caption\n\n// 1. BASIC SANITIZATION\n// Removes HTML tags and trims whitespace to prevent basic XSS/formatting breaks\nlet sanitized = input.replace(/\u003c[^\u003e]*\u003e?/gm, \u0027\u0027).trim();\n\n// 2. MALICIOUS PATTERN DETECTION\n// We look for common \"jailbreak\" or system-level command patterns\nconst maliciousPatterns = [\n  /system prompt/i,\n  /ignore all previous instructions/i,\n  /drop table/i,           // SQL Injection\n  /\u003cscript/i,              // Basic Script Injection\n  /bash/i, /sudo/i,        // Command Injection\n  /forget your rules/i     // LLM Jailbreaking\n];\n\nlet isMalicious = false;\nfor (const pattern of maliciousPatterns) {\n  if (pattern.test(input)) {\n    isMalicious = true;\n    break;\n  }\n}\n\n// Return the cleaned input and the flag\nreturn {\n  sanitizedInput: sanitized,\n  isMalicious: isMalicious,\n  originalLength: input.length\n};\n"
                                     },
