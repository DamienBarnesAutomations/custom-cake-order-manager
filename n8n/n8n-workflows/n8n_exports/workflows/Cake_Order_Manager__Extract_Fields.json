        {
            "parameters": {
                "jsCode": "// Assuming 'input' is the raw response you received\nlet rawData = $input.first().json\n\nfunction unwrapResponse(data) {\n  let result = data;\n\n  // 1. Handle if it's an array: [{...}]\n  if (Array.isArray(result) && result.length > 0) {\n    result = result[0];\n  }\n\n  // 2. Handle if it's nested in an 'output' key: { output: ... }\n  if (result && typeof result === 'object' && result.output) {\n    result = result.output;\n  }\n\n  // 3. Handle if the result is a JSON string (common in 'output' keys)\n  if (typeof result === 'string') {\n    try {\n      result = JSON.parse(result);\n    } catch (e) {\n      console.error(\"Failed to parse stringified JSON:\", e);\n    }\n  }\n\n  return result;\n}\n\nconst cleanIntent = unwrapResponse(rawData);\nreturn cleanIntent;\n"
            },
            "type": "n8n-nodes-base.code",
            "typeVersion": 2,
            "position": [
                640,
                0
            ],
            "id": "eb58e13f-e96e-4c57-9d1f-39e654826799",
            "name": "Code in JavaScript1"
        },
        {
            "parameters": {
                "jsCode": "/**\n * Sanitizes AI output to ensure valid JSON is parsed\n * even if the model included Markdown, preamble, or trailing text.\n */\n\n// Get the raw output from the previous node\nlet rawOutput = $input.first().json.output || \"\";\n\ntry {\n  // 1. Find the start of either an Object { or an Array [\n  const startBrace = rawOutput.indexOf('{');\n  const startBracket = rawOutput.indexOf('[');\n  \n  // Determine which one comes first (ignoring -1)\n  let start = -1;\n  if (startBrace !== -1 && (startBracket === -1 || startBrace < startBracket)) {\n    start = startBrace;\n  } else {\n    start = startBracket;\n  }\n\n  // 2. Find the corresponding last closing character\n  const endBrace = rawOutput.lastIndexOf('}');\n  const endBracket = rawOutput.lastIndexOf(']');\n  const end = Math.max(endBrace, endBracket) + 1;\n\n  if (start === -1 || end <= 0) {\n    throw new Error(\"No JSON structure ({} or []) found in AI output\");\n  }\n\n  // 3. Extract and trim\n  const cleanJsonString = rawOutput.substring(start, end).trim();\n  \n  // 4. Parse the cleaned string\n  const parsed = JSON.parse(cleanJsonString);\n\n  // 5. Return the parsed object\n  return (Array.isArray(parsed)) ? { data: parsed } : parsed;\n\n} catch (error) {\n  return {\n    error: \"Failed to parse AI output\",\n    original_output: rawOutput,\n    details: error.message,\n    ai_hard_failure: true\n  };\n}"
            },
