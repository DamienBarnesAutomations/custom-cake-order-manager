        {
            "parameters": {
                "jsCode": "var config = {...$input.first().json.order_config}\n\nvar cleanData = {}\n\nfor (const key in config){\n  delete config[key].validation_logic\n  delete config[key].visibility_rule\n  delete config[key].option_prices \n  delete config[key].option_labels\n  delete config[key].constraints\n  for (const value in config[key])\n    {\n      if(config[key][value] == null){\n        return {value: config[key]}\n        \n      }\n    }\n  cleanData = Object.fromEntries(\n  Object.entries(config).filter(([_, value]) => value !== null  )\n);\n  \n}\nreturn {order_config:cleanData}"
            },
            "type": "n8n-nodes-base.code",
            "typeVersion": 2,
