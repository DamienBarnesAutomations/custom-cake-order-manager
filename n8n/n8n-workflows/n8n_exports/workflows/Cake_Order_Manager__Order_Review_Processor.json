                  {
                      "parameters":  {
                                         "jsCode":  "const order = $input.first().json;\nconst selections = order.selections || {};\n\nconst name = selections.client_name || \u0027Unknown\u0027;\nconst eventDate = selections.event_date\n  ? new Date(selections.event_date).toLocaleDateString(\u0027en-US\u0027, { weekday: \u0027short\u0027, month: \u0027short\u0027, day: \u0027numeric\u0027, year: \u0027numeric\u0027 })\n  : \u0027Date TBD\u0027;\nconst tiers = selections.tiers ? `${selections.tiers}-tier` : \u0027tier count TBD\u0027;\nconst theme = selections.cake_theme \u0026\u0026 selections.cake_theme !== \u0027None\u0027\n  ? selections.cake_theme\n  : \u0027no theme\u0027;\nconst delivery = selections.delivery === true ? \u0027Delivery\u0027 : selections.delivery === false ? \u0027Pickup\u0027 : \u0027TBD\u0027;\n\nreturn {\n  response_message:\n    `New order to review:\\n\\n` +\n    `Customer: ${name}\\n` +\n    `Event: ${eventDate}\\n` +\n    `Cake: ${tiers} â€” ${theme}\\n` +\n    `Delivery: ${delivery}\\n\\n` +\n    `Open the admin panel to review and respond.`\n};"
                                     },
