                      "id":  "19742e7a-7951-4d40-abf2-149ba69c9bfe",
                      "name":  "Schedule Trigger"
                  },
                  {
                      "parameters":  {
                                         "jsCode":  "const order = $input.first().json;\nconst name = order.selections?.client_name || \u0027there\u0027;\nconst theme = order.selections?.cake_theme \u0026\u0026 order.selections.cake_theme !== \u0027None\u0027\n  ? order.selections.cake_theme\n  : \u0027custom cake\u0027;\nconst date = order.selections?.event_date\n  ? new Date(order.selections.event_date).toLocaleDateString(\u0027en-US\u0027, { weekday: \u0027long\u0027, month: \u0027long\u0027, day: \u0027numeric\u0027 })\n  : \u0027your event date\u0027;\n\nlet response_message = \u0027\u0027;\n\nif (order.review_status === \u0027APPROVED\u0027) {\n  const price = parseFloat(order.quoted_price || 0);\n  const deposit = (price * 0.6).toFixed(2);\n\n  response_message =\n    `Hi ${name}, your ${theme} cake for ${date} has been reviewed and everything looks good.\\n\\n` +\n    `Quoted price: $${price.toFixed(2)}\\n` +\n    `Deposit required (60%): $${deposit}\\n\\n` +\n    (order.user_note ? `Note from us: \"${order.user_note}\"\\n\\n` : \u0027\u0027) +\n    `To lock in your date, please send the deposit of $${deposit}. We\u0027ll follow up with payment details shortly.`;\n\n} else if (order.review_status === \u0027DECLINED\u0027) {\n  response_message =\n    `Hi ${name}, we\u0027ve reviewed your order for ${date} and there\u0027s something we need to sort out before we can move forward.\\n\\n` +\n    (order.user_note ? `${order.user_note}\\n\\n` : \u0027\u0027) +\n    `Reply here and we\u0027ll get it figured out.`;\n\n} else {\n  response_message = \u0027Your order is still being reviewed. We will be in touch shortly.\u0027;\n}\n\nreturn { response_message };"
                                     },
                      "type":  "n8n-nodes-base.code",
