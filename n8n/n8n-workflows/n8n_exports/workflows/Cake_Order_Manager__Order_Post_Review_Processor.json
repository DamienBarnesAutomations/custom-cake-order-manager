            "id": "19742e7a-7951-4d40-abf2-149ba69c9bfe",
            "name": "Schedule Trigger"
        },
        {
            "parameters": {
                "jsCode": "const order = $input.first().json;\nconst name = order.selections?.client_name || 'there';\nconst theme = order.selections?.cake_theme && order.selections.cake_theme !== 'None'\n  ? order.selections.cake_theme\n  : 'custom cake';\nconst date = order.selections?.event_date\n  ? new Date(order.selections.event_date).toLocaleDateString('en-US', { weekday: 'long', month: 'long', day: 'numeric' })\n  : 'your event date';\n\nlet response_message = '';\n\nif (order.review_status === 'APPROVED') {\n  const price = parseFloat(order.quoted_price || 0);\n  const deposit = (price * 0.6).toFixed(2);\n\n  response_message =\n    `Hi ${name}, your ${theme} cake for ${date} has been reviewed and everything looks good.\\n\\n` +\n    `Quoted price: $${price.toFixed(2)}\\n` +\n    `Deposit required (60%): $${deposit}\\n\\n` +\n    (order.user_note ? `Note from us: \"${order.user_note}\"\\n\\n` : '') +\n    `To lock in your date, please send the deposit of $${deposit}. We'll follow up with payment details shortly.`;\n\n} else if (order.review_status === 'DECLINED') {\n  response_message =\n    `Hi ${name}, we've reviewed your order for ${date} and there's something we need to sort out before we can move forward.\\n\\n` +\n    (order.user_note ? `${order.user_note}\\n\\n` : '') +\n    `Reply here and we'll get it figured out.`;\n\n} else {\n  response_message = 'Your order is still being reviewed. We will be in touch shortly.';\n}\n\nreturn { response_message };"
            },
            "type": "n8n-nodes-base.code",
            "typeVersion": 2,
            "position": [
                64,
                0
            ],
            "id": "2153b5e1-c821-44d9-829c-c48368e76793",
