                  {
                      "parameters":  {
                                         "operation":  "executeQuery",
                                         "query":  "SELECT *\nFROM custom_orders co\nINNER JOIN order_review rw on co.order_id = rw.order_id\nINNER JOIN chat_sessions cs on cs.customer_id = co.customer_id\nWHERE (rw.review_status = \u0027APPROVED\u0027 OR rw.review_status = \u0027DECLINED\u0027)\nAND rw.is_processed is FALSE\n\n",
                                         "options":  {

                                                     }
                                     },
