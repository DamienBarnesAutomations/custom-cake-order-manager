    "nodes": [
        {
            "parameters": {
                "operation": "executeQuery",
                "query": "SELECT *\nFROM custom_orders co\nINNER JOIN order_review rw on co.order_id = rw.order_id\nINNER JOIN chat_sessions cs on cs.customer_id = co.customer_id\nWHERE (rw.review_status = 'APPROVED' OR rw.review_status = 'DECLINED')\nAND rw.is_processed is FALSE\n\n",
                "options": {}
            },
            "type": "n8n-nodes-base.postgres",
            "typeVersion": 2.6,
            "position": [
                -160,
                0
            ],
            "id": "576ed69d-f93c-4b8d-b14d-7ad5c4af0be0",
            "name": "Execute a SQL query",
            "credentials": {
                "postgres": {
                    "id": "1lBfXhbGIpsvL7vQ",
                    "name": "Custom Order DB Credentials"
                }
            }
        },
        {
            "parameters": {
                "rule": {
                    "interval": [
                        {
                            "field": "minutes",
                            "minutesInterval": 15
                        }
                    ]
                }
            },
            "type": "n8n-nodes-base.scheduleTrigger",
            "typeVersion": 1.3,
