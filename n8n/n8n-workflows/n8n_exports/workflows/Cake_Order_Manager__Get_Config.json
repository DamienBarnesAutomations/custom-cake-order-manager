                      "id":  "3e4c0fc0-3322-406e-bb68-afc017890428",
                      "name":  "Merge"
                  },
                  {
                      "parameters":  {
                                         "jsCode":  "const retrived_config = $input.first().json.order_config;\nconst order_config = {};\n\nfor (const key in retrived_config) {\n    const current_config = retrived_config[key];\n    const item_config = {};\n    const option_labels = {};\n    \n    const options = current_config.options;\n    \n    // 1. Mapping the basics\n    item_config[\u0027display_name\u0027] = current_config.display_name;\n    item_config[\u0027field_type\u0027] = current_config.field_type;\n    item_config[\u0027scope\u0027] = current_config.scope; // Global vs Tier\n    item_config[\u0027sort_order\u0027] = current_config.sort_order;\n    \n    // 2. Mapping the New Intelligence\n    item_config[\u0027extraction_hint\u0027] = current_config.extraction_hint;\n    item_config[\u0027rules\u0027] = current_config.rules || []; // Integration of the field_rules table\n    \n    // 3. Handle Options\n    item_config[\u0027options\u0027] = [];\n    if (options != null) {\n        // Keeps the array of values for the validation \u0027isAllowed\u0027 check\n        item_config[\u0027options\u0027] = Object.keys(options);\n        \n        for (const opt_key in options) {\n            option_labels[opt_key] = options[opt_key].label;\n        }\n    }\n\n    item_config[\u0027option_labels\u0027] = option_labels;\n    \n    // 4. Placeholder for future price logic if added to field_rules/options\n    item_config[\u0027option_prices\u0027] = {}; \n\n    order_config[key] = item_config;\n}\n\nreturn { order_config: order_config };"
                                     },
